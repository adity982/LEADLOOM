# Flip to 0 for real runs
MOCK_MODE=1

ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# SQLite by default; on Railway: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./leadloom.db

MAX_CONCURRENT_LEADS=5
LLM_REQUESTS_PER_MINUTE=50
SEARCH_REQUESTS_PER_MINUTE=60

# Optional Sheets export
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_NAME=LeadLoom Output
